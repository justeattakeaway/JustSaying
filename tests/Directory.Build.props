<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <ItemGroup>
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" PrivateAssets="All" />
  </ItemGroup>
  <!-- Override the SDK's deterministic source path mapping so that CallerFilePath
       resolves to real disk paths. Shouldly ShouldMatchApproved needs this to find
       approved files. We keep DeterministicSourcePaths=true (required by MS CodeCoverage)
       but map source roots to themselves instead of /_/. -->
  <Target Name="_UseRealSourcePaths" BeforeTargets="_SetPathMap" Condition="'$(ContinuousIntegrationBuild)' == 'true'">
    <ItemGroup>
      <SourceRoot Update="@(SourceRoot)" MappedPath="%(Identity)" />
    </ItemGroup>
  </Target>
</Project>
