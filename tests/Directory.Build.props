<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <ItemGroup>
    <PackageReference Include="coverlet.MTP" PrivateAssets="All" />
    <None Include="$(MSBuildThisFileDirectory)coverlet.mtp.appsettings.json" CopyToOutputDirectory="PreserveNewest" Link="coverlet.mtp.appsettings.json" />
  </ItemGroup>
</Project>
