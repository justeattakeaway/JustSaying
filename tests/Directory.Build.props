<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <ItemGroup>
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" PrivateAssets="All" />
  </ItemGroup>
  <!-- Clear the PathMap right before compilation so CallerFilePath resolves to real
       disk paths (needed by Shouldly ShouldMatchApproved). DeterministicSourcePaths=true
       is still in effect (needed by MS CodeCoverage) but without actual path remapping. -->
  <Target Name="_ClearPathMapForTests" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <PathMap></PathMap>
    </PropertyGroup>
  </Target>
</Project>
