<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <PropertyGroup>
    <!-- Map source paths to themselves so Shouldly ShouldMatchApproved can find
         approved files on disk, while still keeping DeterministicSourcePaths=true
         which MS CodeCoverage requires for instrumentation. -->
    <PathMap Condition="'$(ContinuousIntegrationBuild)' == 'true'">$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)../'))=$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)../'))</PathMap>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" PrivateAssets="All" />
  </ItemGroup>
</Project>
